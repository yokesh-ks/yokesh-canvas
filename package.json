{
  "name": "infinite-canvas",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc -b && vite build",
    "check:types": "tsc --noEmit -p tsconfig.app.json",
    "check:biome": "biome lint --diagnostic-level=error --no-errors-on-unmatched --files-ignore-unknown=true",
    "check": "pnpm run check:types && pnpm run check:biome",
    "lint": "pnpm run check:biome",
    "format": "biome check --write --unsafe",
    "preview": "vite preview"
  },
  "dependencies": {
    "@radix-ui/react-collapsible": "1.1.12",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-navigation-menu": "1.2.14",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-tooltip": "1.2.8",
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.4.2",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.2.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "0.577.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4.2.1",
    "three": "0.182.0",
    "tw-animate-css": "1.4.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "@types/node": "^25.0.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "0.182.0",
    "@vitejs/plugin-react": "^5.1.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "typescript": "~5.9.3",
    "vite": "^7.2.7"
  }
}
